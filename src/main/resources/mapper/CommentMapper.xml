    <!-- 带用户头像的结果映射 -->
    <resultMap id="comment_with_avatar_map" type="com.easyboke.entity.po.Comment" extends="base_result_map">
        <result column="user_avatar" property="userAvatar"/>
        <result column="reply_username" property="replyUsername"/>
    </resultMap>

    <!-- 根据文章ID查询评论列表（含用户头像） -->
    <select id="selectByArticleIdWithAvatar" resultMap="comment_with_avatar_map">
        SELECT c.*, u.avatar as user_avatar,
            rc.username as reply_username
        FROM comment c
        LEFT JOIN user u ON c.user_id = u.id
        LEFT JOIN comment rc ON c.reply_comment_id = rc.id
        WHERE c.article_id = #{articleId}
        <if test="status != null">
            AND c.status = #{status}
        </if>
        ORDER BY c.create_time DESC
    </select>

    <!-- 根据视频ID查询评论列表（含用户头像） -->
    <select id="selectByVideoIdWithAvatar" resultMap="comment_with_avatar_map">
        SELECT c.*, u.avatar as user_avatar,
            rc.username as reply_username
        FROM comment c
        LEFT JOIN user u ON c.user_id = u.id
        LEFT JOIN comment rc ON c.reply_comment_id = rc.id
        WHERE c.video_id = #{videoId}
        <if test="status != null">
            AND c.status = #{status}
        </if>
        ORDER BY c.create_time DESC
    </select>

