<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easyboke.mappers.CommentMapper">
    <!--实体映射-->
    <resultMap id="base_result_map" type="com.easyboke.entity.po.Comment">
        <!--评论ID-->
        <id column="id" property="id"/>
        <!--评论内容-->
        <result column="content" property="content"/>
        <!--评论者ID，0表示游客-->
        <result column="user_id" property="userId"/>
        <!--评论者用户名（游客填写）-->
        <result column="username" property="username"/>
        <!--关联文章ID-->
        <result column="article_id" property="articleId"/>
        <!--关联视频ID-->
        <result column="video_id" property="videoId"/>
        <!--父评论ID，0表示一级评论-->
        <result column="parent_id" property="parentId"/>
        <!--回复的评论ID-->
        <result column="reply_comment_id" property="replyCommentId"/>
        <!--状态：0-待审核，1-已通过，2-已删除-->
        <result column="status" property="status"/>
        <!--点赞数-->
        <result column="like_count" property="likeCount"/>
        <!--评论IP-->
        <result column="ip_address" property="ipAddress"/>
        <!--评论时间-->
        <result column="create_time" property="createTime"/>
        <!--更新时间-->
        <result column="update_time" property="updateTime"/>
   </resultMap>
    <!--通用查询结果列-->
<sql id="base_column_list">
	id,content,user_id,username,article_id,video_id,parent_id,reply_comment_id,status,like_count,ip_address,create_time,update_time
    </sql>

    <!--基础查询条件-->
    <sql id="base_query_condition">
		<if test="query.id!=null">
			and id=#{query.id} 
		</if>
		<if test="query.content!=null and query.content!=''">
			and content=#{query.content} 
		</if>
		<if test="query.userId!=null">
			and user_id=#{query.userId} 
		</if>
		<if test="query.username!=null and query.username!=''">
			and username=#{query.username} 
		</if>
		<if test="query.articleId!=null">
			and article_id=#{query.articleId} 
		</if>
		<if test="query.videoId!=null">
			and video_id=#{query.videoId} 
		</if>
		<if test="query.parentId!=null">
			and parent_id=#{query.parentId} 
		</if>
		<if test="query.replyCommentId!=null">
			and reply_comment_id=#{query.replyCommentId} 
		</if>
		<if test="query.status!=null">
			and status=#{query.status} 
		</if>
		<if test="query.likeCount!=null">
			and like_count=#{query.likeCount} 
		</if>
		<if test="query.ipAddress!=null and query.ipAddress!=''">
			and ip_address=#{query.ipAddress} 
		</if>
		<if test="query.createTime!=null">
			and create_time=#{query.createTime} 
		</if>
		<if test="query.updateTime!=null">
			and update_time=#{query.updateTime} 
		</if>
    </sql>
    <!--扩展查询条件-->
    <sql id="base_query_condition_extend">
		<if test="query.contentFuzzy!=null and query.contentFuzzy!=''">
			and content like concat('%',#{query.contentFuzzy},'%')
		</if>
		<if test="query.usernameFuzzy!=null and query.usernameFuzzy!=''">
			and username like concat('%',#{query.usernameFuzzy},'%')
		</if>
		<if test="query.ipAddressFuzzy!=null and query.ipAddressFuzzy!=''">
			and ip_address like concat('%',#{query.ipAddressFuzzy},'%')
		</if>
		<if test="query.createTimeStart!=null and query.createTimeStart!=''">
			<![CDATA[ and  create_time >= str_to_date(#{query.createTimeStart},'%Y-%m-%d') ]]>
		</if>
		<if test="query.createTimeEnd!=null and query.createTimeEnd!=''">
			<![CDATA[ and  create_time < date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
		</if>
		<if test="query.updateTimeStart!=null and query.updateTimeStart!=''">
			<![CDATA[ and  update_time >= str_to_date(#{query.updateTimeStart},'%Y-%m-%d') ]]>
		</if>
		<if test="query.updateTimeEnd!=null and query.updateTimeEnd!=''">
			<![CDATA[ and  update_time < date_sub(str_to_date(#{query.updateTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
		</if>
    </sql>
    <!--通用查询条件-->
    <sql id="query_condition">
		<where>
			<include refid="base_query_condition"/>
			<include refid="base_query_condition_extend"/>
		</where>
    </sql>
    <!--查询列表-->
	<select id="selectList" resultMap="base_result_map">
		SELECT <include refid="base_column_list"/> FROM comment <include refid="query_condition"/>
		<choose>
				<when test="query.orderBy!=null"> order by ${query.orderBy}</when>
				<otherwise> order by create_time desc</otherwise>
			</choose>
		<if test="query.simplePage!=null">limit #{query.simplePage.start},#{query.simplePage.end}</if>
	</select>
  <!--查询数量-->
	<select id="selectCount"  resultType="java.lang.Integer">
		SELECT count(1) FROM comment <include refid="query_condition"/>
	</select>
