    <!--实体映射-->
    <resultMap id="base_result_map" type="com.easyboke.entity.po.User">
        <!--用户ID-->
        <id column="id" property="id"/>
        <!--用户名-->
        <result column="username" property="username"/>
        <!--账号-->
        <result column="account" property="account"/>
        <!--密码-->
        <result column="password" property="password"/>
        <!--邮箱-->
        <result column="email" property="email"/>
        <!--性别：0-未知，1-男，2-女-->
        <result column="gender" property="gender"/>
        <!--年龄-->
        <result column="age" property="age"/>
        <!--生日-->
        <result column="birthday" property="birthday"/>
        <!--头像URL-->
        <result column="avatar" property="avatar"/> 
        <!--状态：0-禁用，1-启用-->
        <result column="status" property="status"/>
        <!--创建时间-->
        <result column="create_time" property="createTime"/>
        <!--更新时间-->
        <result column="update_time" property="updateTime"/>
   </resultMap>
    <!--通用查询结果列-->
<sql id="base_column_list">
	id,username,account,password,email,gender,age,birthday,avatar,status,create_time,update_time
    </sql>

    <!--基础查询条件-->
    <sql id="base_query_condition">
		<if test="query.id!=null">
			and id=#{query.id} 
		</if>
		<if test="query.username!=null and query.username!=''">
			and username=#{query.username} 
		</if>
		<if test="query.account!=null and query.account!=''">
			and account=#{query.account} 
		</if>
		<if test="query.password!=null and query.password!=''">
			and password=#{query.password} 
		</if>
		<if test="query.gender!=null">
			and gender=#{query.gender} 
		</if>
		<if test="query.age!=null">
			and age=#{query.age} 
		</if>
		<if test="query.status!=null">
			and status=#{query.status} 
		</if>
		<if test="query.createTime!=null">
			and create_time=#{query.createTime} 
		</if>
		<if test="query.updateTime!=null">
			and update_time=#{query.updateTime} 
		</if>
    </sql>
    <!--扩展查询条件-->
    <sql id="base_query_condition_extend">
		<if test="query.usernameFuzzy!=null and query.usernameFuzzy!=''">
			and username like concat('%',#{query.usernameFuzzy},'%')
		</if>
		<if test="query.accountFuzzy!=null and query.accountFuzzy!=''">
			and account like concat('%',#{query.accountFuzzy},'%')
		</if>
		<if test="query.passwordFuzzy!=null and query.passwordFuzzy!=''">
			and password like concat('%',#{query.passwordFuzzy},'%')
		</if>
		<if test="query.createTimeStart!=null and query.createTimeStart!=''">
			<![CDATA[ and  create_time >= str_to_date(#{query.createTimeStart},'%Y-%m-%d') ]]>
		</if>
		<if test="query.createTimeEnd!=null and query.createTimeEnd!=''">
			<![CDATA[ and  create_time < date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
		</if>
		<if test="query.updateTimeStart!=null and query.updateTimeStart!=''">
			<![CDATA[ and  update_time >= str_to_date(#{query.updateTimeStart},'%Y-%m-%d') ]]>
		</if>
		<if test="query.updateTimeEnd!=null and query.updateTimeEnd!=''">
			<![CDATA[ and  update_time < date_sub(str_to_date(#{query.updateTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
		</if>
    </sql>
    <!--通用查询条件-->
    <sql id="query_condition">
		<where>
			<include refid="base_query_condition"/>
			<include refid="base_query_condition_extend"/>
		</where>
    </sql>
    <!--查询列表-->
	<select id="selectList" resultMap="base_result_map">
		SELECT <include refid="base_column_list"/> FROM user <include refid="query_condition"/>
		<if test="query.orderBy!=null"> order by ${query.orderBy}</if>
		<if test="query.simplePage!=null">limit #{query.simplePage.start},#{query.simplePage.end}</if>
	</select>
  <!--查询数量-->
	<select id="selectCount"  resultType="java.lang.Integer">
		SELECT count(1) FROM user <include refid="query_condition"/>
	</select>
