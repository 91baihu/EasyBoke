	<!-- 查询用户年龄分布-->
	<select id="selectAgeDistribution" resultType="java.util.Map">
		SELECT
			SUM(CASE WHEN age IS NULL OR age &lt; 18 THEN 1 ELSE 0 END) AS under18,
			SUM(CASE WHEN age >= 18 AND age &lt;= 25 THEN 1 ELSE 0 END) AS age18_25,
			SUM(CASE WHEN age >= 26 AND age &lt;= 35 THEN 1 ELSE 0 END) AS age26_35,
			SUM(CASE WHEN age >= 36 AND age &lt;= 45 THEN 1 ELSE 0 END) AS age36_45,
			SUM(CASE WHEN age > 45 THEN 1 ELSE 0 END) AS above45
		FROM user
