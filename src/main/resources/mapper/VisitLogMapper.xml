	</delete>

    <!-- 统计查询：总访问量、今日访问量、独立IP数 -->
    <select id="selectStatsSummary" resultType="java.util.HashMap">
        SELECT
            (SELECT COUNT(*) FROM visit_log) as totalVisits,
            (SELECT COUNT(*) FROM visit_log WHERE DATE(visit_time) = CURDATE()) as todayVisits,
            (SELECT COUNT(DISTINCT ip_address) FROM visit_log) as uniqueIpCount,
            (SELECT COUNT(*) FROM visit_log WHERE user_id > 0) as userVisitCount,
            (SELECT COUNT(*) FROM visit_log WHERE user_id = 0) as guestVisitCount
    </select>

    <!-- 统计查询：文章/视频/标签/分类 TOP排行（按访问量） -->
    <select id="selectTopTargets" resultType="java.util.HashMap">
        SELECT target_type as targetType, target_id as targetId, COUNT(*) as visitCount
        FROM visit_log
        WHERE target_type = #{targetType}
        GROUP BY target_id
        ORDER BY visitCount DESC
        LIMIT #{limit}
    </select>

    <!-- 统计查询：分类文章访问量占比 -->
    <select id="selectCategoryStats" resultType="java.util.HashMap">
        SELECT c.id as categoryId, c.name as categoryName, COUNT(vl.id) as visitCount
        FROM article a
        LEFT JOIN category c ON a.category_id = c.id
        LEFT JOIN visit_log vl ON vl.target_id = a.id AND vl.target_type = 'article'
        WHERE a.status = 1
        GROUP BY c.id, c.name
        ORDER BY visitCount DESC
    </select>

