<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easyboke.mappers.VisitLogMapper">
    <!--实体映射-->
    <resultMap id="base_result_map" type="com.easyboke.entity.po.VisitLog">
        <!--ID-->
        <id column="id" property="id"/>
        <!--访问类型：article/video-->
        <result column="target_type" property="targetType"/>
        <!--目标ID-->
        <result column="target_id" property="targetId"/>
        <!--访问者ID，0表示游客-->
        <result column="user_id" property="userId"/>
        <!--访问者性别：0-未知，1-男，2-女-->
        <result column="gender" property="gender"/>
        <!--访问者年龄，0表示未知-->
        <result column="age" property="age"/>
        <!--访问IP-->
        <result column="ip_address" property="ipAddress"/>
        <!--浏览器信息-->
        <result column="user_agent" property="userAgent"/>
        <!--访问时间-->
        <result column="visit_time" property="visitTime"/>
   </resultMap>
    <!--通用查询结果列-->
<sql id="base_column_list">
	id,target_type,target_id,user_id,gender,age,ip_address,user_agent,visit_time
    </sql>

    <!--基础查询条件-->
    <sql id="base_query_condition">
		<if test="query.id!=null">
			and id=#{query.id} 
		</if>
		<if test="query.targetType!=null and query.targetType!=''">
			and target_type=#{query.targetType} 
		</if>
		<if test="query.targetId!=null">
			and target_id=#{query.targetId} 
		</if>
		<if test="query.userId!=null">
			and user_id=#{query.userId} 
		</if>
		<if test="query.gender!=null">
			and gender=#{query.gender} 
		</if>
		<if test="query.age!=null">
			and age=#{query.age} 
		</if>
		<if test="query.ipAddress!=null and query.ipAddress!=''">
			and ip_address=#{query.ipAddress} 
		</if>
		<if test="query.userAgent!=null and query.userAgent!=''">
			and user_agent=#{query.userAgent} 
		</if>
		<if test="query.visitTime!=null">
			and visit_time=#{query.visitTime} 
		</if>
    </sql>
    <!--扩展查询条件-->
    <sql id="base_query_condition_extend">
		<if test="query.targetTypeFuzzy!=null and query.targetTypeFuzzy!=''">
			and target_type like concat('%',#{query.targetTypeFuzzy},'%')
		</if>
		<if test="query.ipAddressFuzzy!=null and query.ipAddressFuzzy!=''">
			and ip_address like concat('%',#{query.ipAddressFuzzy},'%')
		</if>
		<if test="query.userAgentFuzzy!=null and query.userAgentFuzzy!=''">
			and user_agent like concat('%',#{query.userAgentFuzzy},'%')
		</if>
		<if test="query.visitTimeStart!=null and query.visitTimeStart!=''">
			<![CDATA[ and  visit_time >= str_to_date(#{query.visitTimeStart},'%Y-%m-%d') ]]>
		</if>
		<if test="query.visitTimeEnd!=null and query.visitTimeEnd!=''">
			<![CDATA[ and  visit_time < date_sub(str_to_date(#{query.visitTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
		</if>
    </sql>
    <!--通用查询条件-->
    <sql id="query_condition">
		<where>
			<include refid="base_query_condition"/>
			<include refid="base_query_condition_extend"/>
		</where>
    </sql>
    <!--查询列表-->
	<select id="selectList" resultMap="base_result_map">
		SELECT <include refid="base_column_list"/> FROM visit_log <include refid="query_condition"/>
		<if test="query.orderBy!=null"> order by ${query.orderBy}</if>
		<if test="query.simplePage!=null">limit #{query.simplePage.start},#{query.simplePage.end}</if>
	</select>
  <!--查询数量-->
	<select id="selectCount"  resultType="java.lang.Integer">
		SELECT count(1) FROM visit_log <include refid="query_condition"/>
	</select>
