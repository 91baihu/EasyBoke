<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easyboke.mappers.TagMapper">
    <!--实体映射-->
    <resultMap id="base_result_map" type="com.easyboke.entity.po.Tag">
        <!--标签ID-->
        <id column="id" property="id"/>
        <!--标签名称-->
        <result column="tag_name" property="tagName"/>
        <!--使用次数-->
        <result column="use_count" property="useCount"/>
        <!--创建时间-->
        <result column="create_time" property="createTime"/>
   </resultMap>
    <!--通用查询结果列-->
<sql id="base_column_list">
	id,tag_name,use_count,create_time
    </sql>

    <!--基础查询条件-->
    <sql id="base_query_condition">
		<if test="query.id!=null">
			and id=#{query.id} 
		</if>
		<if test="query.tagName!=null and query.tagName!=''">
			and tag_name=#{query.tagName} 
		</if>
		<if test="query.useCount!=null">
			and use_count=#{query.useCount} 
		</if>
		<if test="query.createTime!=null">
			and create_time=#{query.createTime} 
		</if>
    </sql>
    <!--扩展查询条件-->
    <sql id="base_query_condition_extend">
		<if test="query.tagNameFuzzy!=null and query.tagNameFuzzy!=''">
			and tag_name like concat('%',#{query.tagNameFuzzy},'%')
		</if>
		<if test="query.createTimeStart!=null and query.createTimeStart!=''">
			<![CDATA[ and  create_time >= str_to_date(#{query.createTimeStart},'%Y-%m-%d') ]]>
		</if>
		<if test="query.createTimeEnd!=null and query.createTimeEnd!=''">
			<![CDATA[ and  create_time < date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
		</if>
    </sql>
    <!--通用查询条件-->
    <sql id="query_condition">
		<where>
			<include refid="base_query_condition"/>
			<include refid="base_query_condition_extend"/>
		</where>
    </sql>
    <!--查询列表-->
	<select id="selectList" resultMap="base_result_map">
		SELECT <include refid="base_column_list"/> FROM tag <include refid="query_condition"/>
		<if test="query.orderBy!=null"> order by ${query.orderBy}</if>
		<if test="query.simplePage!=null">limit #{query.simplePage.start},#{query.simplePage.end}</if>
	</select>
  <!--查询数量-->
	<select id="selectCount"  resultType="java.lang.Integer">
		SELECT count(1) FROM tag <include refid="query_condition"/>
	</select>
    <!--插入(匹配有值的字段)-->
	<insert id="insert"  parameterType="com.easyboke.entity.po.Tag">
		<selectKey keyProperty="bean.id" resultType="Integer" order="AFTER">
			SELECT LAST_INSERT_ID();
		</selectKey>
		insert into tag
		<trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.id!=null">
				id,
			</if>
			<if test="bean.tagName!=null">
				tag_name,
			</if>
			<if test="bean.useCount!=null">
				use_count,
			</if>
			<if test="bean.createTime!=null">
				create_time,
			</if>
		</trim>
		<trim prefix="values(" suffix=")" suffixOverrides=",">
 			<if test="bean.id!=null">
 				#{bean.id},
			 </if>
 			<if test="bean.tagName!=null">
 				#{bean.tagName},
			 </if>
 			<if test="bean.useCount!=null">
 				#{bean.useCount},
			 </if>
 			<if test="bean.createTime!=null">
 				#{bean.createTime},
			 </if>
		 </trim>
	</insert>
    <!--插入或者更新(匹配有值的字段)-->
	<insert id="insertOrUpdate"  parameterType="com.easyboke.entity.po.Tag">
		insert into tag
		<trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.id!=null">
				id,
			</if>
			<if test="bean.tagName!=null">
				tag_name,
			</if>
			<if test="bean.useCount!=null">
				use_count,
			</if>
			<if test="bean.createTime!=null">
				create_time,
			</if>
		</trim>
		<trim prefix="values(" suffix=")" suffixOverrides=",">
 			<if test="bean.id!=null">
 				#{bean.id},
			 </if>
 			<if test="bean.tagName!=null">
 				#{bean.tagName},
			 </if>
 			<if test="bean.useCount!=null">
 				#{bean.useCount},
			 </if>
 			<if test="bean.createTime!=null">
 				#{bean.createTime},
			 </if>
		 </trim>
		on DUPLICATE key update
		<trim prefix="" suffix="" suffixOverrides=",">
			<if test="bean.useCount!=null">
				use_count =VALUES(use_count),
			</if>
			<if test="bean.createTime!=null">
				create_time =VALUES(create_time),
			</if>

		</trim>
	</insert>
	<!--添加(批量插入)-->
	<insert id="insertBatch" parameterType="com.easyboke.entity.po.Tag">
		insert into tag(tag_name,use_count,create_time)values
		<foreach collection="list" item="item" separator=",">
			(#{item.tagName},#{item.useCount},#{item.createTime})
		</foreach>
	 </insert>
	<!--批量插入或更新-->
	<insert id="insertOrUpdateBatch" parameterType="com.easyboke.entity.po.Tag">
		insert into tag(tag_name,use_count,create_time)values
		<foreach collection="list" item="item" separator=",">
			(#{item.tagName},#{item.useCount},#{item.createTime})
		</foreach>
			on DUPLICATE key update
            id= VALUES(id),tag_name= VALUES(tag_name),use_count= VALUES(use_count),create_time= VALUES(create_time)
	</insert>
	<!-- 根据"Id"查询-->
	<select id="selectById" resultMap="base_result_map">
		select <include refid="base_column_list"/>  from tag where id=#{id}
	</select>
	<!-- 根据"Id"更新-->
	<update id="updateById" parameterType="com.easyboke.entity.po.Tag">
		update  tag
		<set>
			<if test="bean.id!=null">
			id=#{bean.id},
			</if>
			<if test="bean.tagName!=null">
			tag_name=#{bean.tagName},
			</if>
			<if test="bean.useCount!=null">
			use_count=#{bean.useCount},
			</if>
			<if test="bean.createTime!=null">
			create_time=#{bean.createTime},
			</if>
		</set>
		<where>
			id=#{id}
		</where>
	</update>

	<!-- 根据"Id"删除-->
	<delete id="deleteById">
		delete from tag where id=#{id}
	</delete>

	<!-- 根据"TagName"查询-->
	<select id="selectByTagName" resultMap="base_result_map">
		select <include refid="base_column_list"/>  from tag where tag_name=#{tagName}
	</select>
	<!-- 根据"TagName"更新-->
	<update id="updateByTagName" parameterType="com.easyboke.entity.po.Tag">
		update  tag
		<set>
			<if test="bean.id!=null">
			id=#{bean.id},
			</if>
			<if test="bean.tagName!=null">
			tag_name=#{bean.tagName},
			</if>
			<if test="bean.useCount!=null">
			use_count=#{bean.useCount},
			</if>
			<if test="bean.createTime!=null">
			create_time=#{bean.createTime},
			</if>
		</set>
		<where>
			tag_name=#{tagName}
		</where>
	</update>

	<!-- 根据"TagName"删除-->
	<delete id="deleteByTagName">
		delete from tag where tag_name=#{tagName}
	</delete>

</mapper>